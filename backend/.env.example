DATABASE_URL=postgresql://usuario:password@host/basededatos?sslmode=require
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

# --- IA (resúmenes y esquemas) ---
# Proveedor: "groq" (por defecto, gratis) o "gemini".
IA_PROVIDER=groq
# Groq (crea una clave gratis en https://console.groq.com/keys)
GROQ_API_KEY=tu-api-key-de-groq
GROQ_MODEL=llama-3.3-70b-versatile
# Gemini (solo si IA_PROVIDER=gemini)
GEMINI_API_KEY=tu-api-key-de-gemini
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_HOSTED_DOMAIN=academiamega.net

# Roles: emails que se promocionan automáticamente al iniciar sesión (separados por comas)
ADMIN_EMAILS=director@academiamega.net
PROFESOR_EMAILS=profe1@academiamega.net,profe2@academiamega.net

# Monitorización de errores (opcional): si se define, se activa Sentry
SENTRY_DSN=

# Tamaño máximo por PDF de temario en MB (se guardan en la BD)
MAX_PDF_MB=10
